    /* ─────────────────────────────────────────────
     * MOUNT
     * ───────────────────────────────────────────── */
    function mount() {
        if (!isMobile()) {
            if (_mounted) {
                _mounted = false;
                stopCarousel();
                removeInjectedNodes();
            }
            return false;
        }

        var container = document.querySelector(CONTAINER_SEL);
        if (!container) return false;

        if (_mounted) {
            var existingIndicator = document.getElementById(INDICATOR_ID);
            if (existingIndicator && container.contains(existingIndicator)) return true;
            _mounted = false;
            stopCarousel();
        }

        injectStyles();
        removeInjectedNodes();
        patchHeading(container);

        var indicator = buildStepIndicator();
        var perks     = buildPerksCarousel();
        var heading   = container.querySelector(".banner-text");

        // ✅ Defer DOM insertion to avoid layout shift / scroll jump
        requestAnimationFrame(function() {
            if (heading) {
                container.insertBefore(indicator, heading);
                heading.insertAdjacentElement("afterend", perks.carousel);
                perks.carousel.insertAdjacentElement("afterend", perks.dots);
            } else {
                container.insertBefore(perks.dots, container.firstChild);
                container.insertBefore(perks.carousel, container.firstChild);
                container.insertBefore(indicator, container.firstChild);
            }
            startCarousel();
            _mounted = true;
            startContainerObserver(); // ✅ Start watching container after mount
        });

        return true;
    }

    /* ─────────────────────────────────────────────
     * CONTAINER OBSERVER — replaces heartbeat ✅
     * ───────────────────────────────────────────── */
    function startContainerObserver() {
        if (_containerObserver) return;

        var container = document.querySelector(CONTAINER_SEL);
        if (!container) return;

        _containerObserver = new MutationObserver(function() {
            var indicator = document.getElementById(INDICATOR_ID);
            if (!indicator || !container.contains(indicator)) {
                _mounted = false;
                stopCarousel();
                // ✅ Defer re-mount to next paint — no scroll jump
                requestAnimationFrame(function() {
                    mount();
                });
            }
        });

        _containerObserver.observe(container, {
            childList: true,
            subtree: true
        });
    }

    /* ─────────────────────────────────────────────
     * MUTATION OBSERVER — watches for container appearing
     * ───────────────────────────────────────────── */
    function startObserver() {
        if (_observer) return;

        if (typeof MutationObserver === "undefined") {
            var pollTimer = setInterval(function() {
                if (mount()) clearInterval(pollTimer);
            }, 500);
            return;
        }

        _observer = new MutationObserver(function() {
            if (!_mounted) mount();
        });

        _observer.observe(document.body || document.documentElement, {
            childList: true,
            subtree: true
        });
    }

    /* ─────────────────────────────────────────────
     * VISIBILITY — pause carousel when tab hidden
     * ───────────────────────────────────────────── */
    function onVisibilityChange() {
        if (document.visibilityState === "hidden") {
            stopCarousel();
        } else if (_mounted && isMobile()) {
            startCarousel();
        }
    }

    /* ─────────────────────────────────────────────
     * RESIZE — debounced ✅
     * ───────────────────────────────────────────── */
    function onResize() {
        if (!isMobile() && _mounted) {
            _mounted = false;
            stopCarousel();
            removeInjectedNodes();
            if (_containerObserver) {
                _containerObserver.disconnect();
                _containerObserver = null;
            }
        } else if (isMobile() && !_mounted) {
            mount();
        }
    }

    function onResizeDebounced() {
        clearTimeout(_resizeTimer);
        _resizeTimer = setTimeout(onResize, 150); // ✅ 150ms debounce
    }

    /* ─────────────────────────────────────────────
     * PUBLIC DESTROY
     * ───────────────────────────────────────────── */
    window.__igCabInjectorDestroy = function() {
        stopCarousel();

        if (_observer) {
            _observer.disconnect();
            _observer = null;
        }

        // ✅ Disconnect container observer
        if (_containerObserver) {
            _containerObserver.disconnect();
            _containerObserver = null;
        }

        // ✅ Clear debounce timer
        clearTimeout(_resizeTimer);
        _resizeTimer = null;

        document.removeEventListener("visibilitychange", onVisibilityChange);
        window.removeEventListener("resize", onResizeDebounced); // ✅ Matches debounced ref

        removeInjectedNodes();

        var styleEl = document.getElementById(STYLE_ID);
        if (styleEl && styleEl.parentNode) styleEl.parentNode.removeChild(styleEl);

        var p = document.querySelector(".banner-text p");
        if (p) p.textContent = "Heading to the airport? Book a cab now";

        _mounted        = false;
        _carouselDots   = [];
        _carouselIndex  = 0;
    };

    /* ─────────────────────────────────────────────
     * INIT
     * ───────────────────────────────────────────── */
    function init() {
        document.addEventListener("visibilitychange", onVisibilityChange);
        window.addEventListener("resize", onResizeDebounced); // ✅ Debounced
        mount();
        startObserver();
        // ✅ No startHeartbeat() — container observer handles re-mount
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
    } else {
        init();
    }

})();
