                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Bangkok.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Gateway_of_India@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Pattaya.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Kuala_Lumpur.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Hanoi.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Abu_Dhabi.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Taj_Mahal@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Canal_Cruise@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/s6web/in/en/assets/target/sightseeing-banners/Explore_more_cities_web.png"
            ];

            const mobileImages = [
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Burj-Khalifa-mweb@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Hawa-Mahal-mweb@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Gardens-by-the-Bay-mweb@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/James_Bond_Island@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Beaches_&_Churches_Goa@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Ho_Chi_Minh.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Gobustan-mweb@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Bangkok.mweb.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Gateway_of_India@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Pattaya.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Kuala_Lumpur.mweb.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Hanoi.mweb.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Abu_Dhabi.mweb.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Taj_Mahal@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/marketplace/in/en/assets/Sight_seeing/Canal-Cruise-mweb@3x.jpg?ui-ux=newui",
                "https://www.goindigo.in/content/dam/s6web/in/en/assets/target/sightseeing-banners/Expore_more_cities_Mweb.png"
            ];

            const overlayLabels = [
                "Dubai ", "Jaipur", "Singapore", "Phuket", "Goa", "Ho Chi Minh ", "Baku", "Bangkok", "Delhi", "Pattaya", "Kuala Lumpur ", "Hanoi", "Abu Dhabi", "Agra", "Amsterdam"
            ];

            const links = [
                "https://www.goindigo.in/sightseeing/select.html?destinationId=12633&searchTerm=Dubai&destinationType=City&country=United+Arab+Emirates",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=11649&searchTerm=Jaipur&destinationType=City&country=India",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=13229&searchTerm=Singapore&destinationType=City&country=Singapore",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=12548&searchTerm=Phuket&destinationType=City&country=Thailand",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=562427971348613&searchTerm=Goa&destinationType=City&country=India",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=12662&searchTerm=Ho+Chi+Minh+City&destinationType=City&country=Vietnam",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=10881&searchTerm=Baku&destinationType=City&country=Azerbaijan",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=12532&searchTerm=Bangkok&destinationType=City&country=Thailand",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=11667&searchTerm=New+Delhi&destinationType=City&country=India",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=12547&searchTerm=Pattaya&destinationType=City&country=Thailand",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=11965&searchTerm=Kuala+Lumpur&destinationType=City&country=Malaysia ",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=12661&searchTerm=Hanoi&destinationType=City&country=Vietnam",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=12630&searchTerm=Abu+Dhabi&destinationType=City&country=United+Arab+Emirates ",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=11622&searchTerm=Agra&destinationType=City&country=India",
                "https://www.goindigo.in/sightseeing/select.html?destinationId=10799&searchTerm=Amsterdam&destinationType=City&country=Netherlands",
                "https://www.goindigo.in/sightseeing.html?linkNav=New%20Rail%20Homepage"
            ];

            const track = carouselSection.querySelector('.carousel-track');
            const trackWrapper = carouselSection.querySelector('.carousel-track-wrapper');
            const images = isMobile ? mobileImages : desktopImages;

            images.forEach((src, i) => {
                const a = document.createElement('a');
                a.href = links[i];
                a.target = "_blank";
                // Overlay wrapper
                const overlayWrapper = document.createElement('div');
                overlayWrapper.style.position = 'relative';
                overlayWrapper.style.width = '100%';
                overlayWrapper.style.height = '100%';

                const img = document.createElement('img');
                img.src = src;
                img.style.width = '100%';
                img.style.height = '100%';
                img.style.borderRadius = '8px';
                img.style.objectFit = 'cover';

                const overlay = document.createElement('div');
                overlay.className = 'card-overlay';

                const overlayText = document.createElement('span');
                overlayText.textContent = overlayLabels[i] || '';
                overlayText.className = 'overlay-label';

                overlay.appendChild(overlayText);
                overlayWrapper.appendChild(img);
                overlayWrapper.appendChild(overlay);

                a.appendChild(overlayWrapper);
                track.appendChild(a);
            });

            const visibleBlocks = 4;
            const blockWidth = 282 + 15;
            let currentIndex = 0;

            const leftArrow = carouselSection.querySelector('.arrow.left');
            const rightArrow = carouselSection.querySelector('.arrow.right');

            function scrollToIndex(index) {
                const maxIndex = images.length - visibleBlocks;
                currentIndex = Math.max(0, Math.min(index, maxIndex));
                const scrollAmount = currentIndex * blockWidth;
                trackWrapper.scrollTo({
                    left: scrollAmount,
                    behavior: 'smooth'
                });
                updateArrowStates();
            }

            function updateArrowStates() {
                const maxScrollLeft = trackWrapper.scrollWidth - trackWrapper.clientWidth;
                const currentScroll = trackWrapper.scrollLeft;
                leftArrow.style.background = currentScroll <= 0 ? 'rgba(34, 34, 34, .1)' : '#1a1a8a';
                rightArrow.style.background = currentScroll >= maxScrollLeft - 5 ? '#ccc' : '#009';
            }

            leftArrow.addEventListener('click', () => scrollToIndex(currentIndex - 1));
            rightArrow.addEventListener('click', () => scrollToIndex(currentIndex + 1));
            updateArrowStates();
        }

        function waitForSecondElement(selector, callback) {
            const elements = document.querySelectorAll(selector);
            if (elements.length >= 2) {
                callback(elements[1]);
                return;
            }

            const observer = new MutationObserver(() => {
                const updatedElements = document.querySelectorAll(selector);
                if (updatedElements.length >= 2) {
                    observer.disconnect();
                    callback(updatedElements[1]);
                }
            });

            observer.observe(document.body, {
                childList: true,
                subtree: true,
            });
        }

        const selectorToUse = isMobile ? mobileSelector : desktopSelector;
        waitForSecondElement(selectorToUse, insertCarouselAfter);
    })();
</script>
