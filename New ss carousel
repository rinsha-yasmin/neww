      rightArrow.style.background = scroll >= maxScroll - 5 ? '#ccc' : '#0000cc';
      leftArrow.disabled = scroll <= 0;
      rightArrow.disabled = scroll >= maxScroll - 5;
    }

    function scrollToIndex(index) {
      const maxIndex = images.length - VISIBLE_CARDS;
      currentIndex = Math.max(0, Math.min(index, maxIndex));
      trackWrapper.scrollTo({ left: currentIndex * CARD_WIDTH, behavior: 'smooth' });
    }

